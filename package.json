{
  "name": "jinil-label",
  "productName": "진일 라벨",
  "private": true,
  "type": "module",
  "description": "Jinil Todo Application",
  "author": "Jinil",
  "version": "1.1.14",
  "main": "jinil web app/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && cross-env CSC_SKIP=true electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "firebase": "^11.10.0",
    "globals": "^16.5.0",
    "jsbarcode": "^3.12.3",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.0",
    "sweetalert2": "^11.26.21",
    "tailwindcss": "^4.2.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.jinil.todos",
    "productName": "진일 라벨",
    "compression": "maximum",
    "removePackageScripts": true,
    "removePackageKeywords": true,
    "directories": {
      "output": "dist_electron",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "jinil web app/**/*"
    ],
    "asar": true,
    "win": {
      "icon": "public/logo.png",
      "target": [
        "nsis"
      ],
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "perMachine": false,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "goz86",
        "repo": "jinil-app",
        "releaseType": "release"
      }
    ]
  }
}
